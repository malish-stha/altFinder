# Spring Datasource (Supabase Postgres)
# Replace these placeholders with your actual Supabase DB credentials
spring.datasource.url=jdbc:postgresql://your-supabase-host:5432/your-db-name
spring.datasource.username=your_db_username
spring.datasource.password=your_db_password

# Clerk OAuth2 JWKS endpoint (JWT verification)
spring.security.oauth2.resourceserver.jwt.jwk-set-uri=https://api.clerk.com/v1/jwks

# Gemini API Key configuration
gemini.api.key=your_gemini_api_key_here
